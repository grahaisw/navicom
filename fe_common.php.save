//echo 'crot: ' . $room_key . '<br>';
$room_id = '';
$lang_id = '';
$node_id = '';
$auth = authenticate_room($room_id, $room_key, $lang_id, $node_id);

$sql = "SELECT room_name FROM ".ROOMS_TABLE." WHERE room_id = ".$room_id."";
$result = $db->sql_query($sql);
$room_name = $db->sql_fetchfield('room_name');
$db->sql_freeresult($result);

/** BEGIN FOS Integration **/

// GET ROOM STATUS FROM FOS
$ch = curl_init();
curl_setopt($ch, CURLOPT_URL, $pms_config['url_request']."GetRoomStatus?RoomNo=".$room_name);
curl_setopt($ch, CURLOPT_RETURNTRANSFER, 1);
$response = curl_exec($ch); 
echo '<div style="background-color:#fff">'. $pms_config['url_request']."GetRoomStatus?RoomNo=".$room_name.'</div>'; exit;echo '<div style="background-color:#fff">'. $pms_config['url_request']."GetRoomStatus?RoomNo=".$room_name.'</div>'; exit;echo '<div style="background-color:#fff">'. $pms_config['url_request']."GetRoomStatus?RoomNo=".$room_name.'</div>'; exit;
if(curl_errno($ch)) // jika koneksi ke PMS putus
{
	$guests_name = get_guests_data();

	if ( empty(trim($guests_name[0]['resv_id'])) && $config['lock_on_empty_room'] && !defined('BYPASS_LOCK'))
	{
		$lock = request_var('lock',0);
		
		if(empty($lock))
		{
		redirect('lock.'.$phpEx . '?lock=1');
		}
		
	}
}
else // jika koneksi ke PMS berhasil
{
	$xml = new SimpleXmlElement($response);
	$room_status = trim($xml->Entry->RoomStatusId); 	

	curl_close($ch);
	

	$sql = "SELECT COUNT(*) AS total_data FROM ".GUESTS_TABLE." WHERE room_name = '".$room_name."'";
	$result = $db->sql_query($sql);
	$count = $db->sql_fetchfield('total_data');

	$guests_name = get_guests_data();
	
	//require($tonjaw_root_path . $config['pms_path'] . 'common_pms.' . $phpEx);
	//$pms->checkout($xml);
	
	if($room_status == 1 && $count == 0) { // blm ter-checkin di IPTV
		require($tonjaw_root_path . $config['pms_path'] . 'common_pms.' . $phpEx);	
		$pms->checkin($xml);
		
	} else if($room_status == 0 && $count == 1) { // blm ter-checkout di IPTV
		require($tonjaw_root_path . $config['pms_path'] . 'common_pms.' . $phpEx);
		$pms->checkout($xml);

		if ( (empty($guests_name) || empty($guests_name[0]['resv_id'])) && $config['lock_on_empty_room'] && !defined('BYPASS_LOCK'))
		{
			$lock = request_var('lock',0);
			
			if(empty($lock))
			{
			redirect('lock.'.$phpEx . '?lock=1');
			}
			
		}
	}
}

/** END FOS Integration **/

require($tonjaw_root_path . $config['language_path'] . $lang_id . '.' . $phpEx);

